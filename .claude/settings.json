{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_EFFORT_LEVEL": "medium"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(mix deps.get:*)",
      "Bash(mix ecto.migrate:*)",
      "Bash(mix test:*)",
      "Bash(mix format:*)",
      "Bash(mix credo:*)",
      "Bash(mix sobelow:*)",
      "Bash(mix assets.build:*)",
      "Bash(curl:*)"
    ]
  },
  "model": "sonnet",
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "ast-grep@ast-grep-marketplace": true,
    "frontend-design@claude-code-plugins": true,
    "elixir-phoenix-guide@elixir-phoenix-guide": true,
    "context-mode@context-mode": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "elixir-phoenix-guide": {
      "source": {
        "source": "github",
        "repo": "j-morgan6/elixir-phoenix-guide"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "claude-code-plugin": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "hexdocs-mcp",
    "sequential-thinking",
    "filesystem",
    "postgres"
  ]
}
